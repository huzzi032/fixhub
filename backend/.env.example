# Supabase Postgres connection string.
# Always paste the exact Session Pooler URI copied from Supabase Dashboard.
# Then replace [YOUR-PASSWORD] with a URL-encoded password.
# Example encoded chars: ! -> %21, ? -> %3F
DATABASE_URL=postgresql://[USERNAME_FROM_DASHBOARD]:[URL_ENCODED_PASSWORD]@[POOLER_HOST_FROM_DASHBOARD]:6543/postgres

# Optional: set false only if your environment does not support SSL.
DATABASE_SSL=true

JWT_SECRET=replace-with-a-long-random-secret

# Development OTP fallback for phone login
FIXHUB_DEV_OTP=123456
