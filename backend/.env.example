# Supabase Postgres connection string.
# Use Session Pooler for Vercel/IPv4 networks and URL-encode the password.
# Example encoded chars: ! -> %21, ? -> %3F
DATABASE_URL=postgresql://postgres:[URL_ENCODED_PASSWORD]@aws-0-your-region.pooler.supabase.com:6543/postgres

# Optional: set false only if your environment does not support SSL.
DATABASE_SSL=true

JWT_SECRET=replace-with-a-long-random-secret

# Development OTP fallback for phone login
FIXHUB_DEV_OTP=123456
